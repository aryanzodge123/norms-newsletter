---
// DESIGN.md section 4, SectionLabel. Caps label in --oxide over a 1px --rule
// underline. Section names render in full ("Artificial intelligence", not "AI").
interface Props {
  text: string;
}
const { text } = Astro.props;
---

<h2 class="section-label">{text}</h2>

<style>
  .section-label {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--oxide);
    margin: 0 0 12px;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--rule);
  }
  @media (max-width: 720px) {
    .section-label { font-size: 11.5px; }
  }
</style>
