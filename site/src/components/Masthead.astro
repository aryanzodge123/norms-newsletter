---
// DESIGN.md section 4, Masthead. Three columns on one baseline. The frame
// never changes (principle 1): the double rule sits directly below in all
// cases. On edition pages the slots are date / wordmark / "No. NNN". On other
// pages the left slot is a back link and the right slot names the page.
import { href } from '../lib/urls';
import { formatDateLong } from '../lib/editions';

interface Props {
  variant?: 'edition' | 'page';
  date?: string;
  editionNumber?: number;
  pageName?: string;
}

const { variant = 'edition', date, editionNumber, pageName } = Astro.props;
---

<header class="masthead-wrap">
  <div class="container masthead" class:list={[{ page: variant === 'page' }]}>
    <div class="slot left">
      {
        variant === 'edition'
          ? <span class="mono">{date ? formatDateLong(date) : ''}</span>
          : <a class="mono back" href={href('/')}>Today's brief</a>
      }
    </div>
    <div class="slot center">
      <a class="wordmark" href={href('/')}>Norm's Newsletter</a>
    </div>
    <div class="slot right">
      {
        variant === 'edition'
          ? <span class="mono">No. {String(editionNumber ?? 0).padStart(3, '0')}</span>
          : <span class="mono page-name">{pageName}</span>
      }
    </div>
  </div>
  <div class="container"><hr class="masthead-rule" /></div>
</header>

<style>
  .masthead {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: baseline;
    padding-top: 20px;
    padding-bottom: 10px;
    gap: 12px;
  }
  .slot.left { text-align: left; }
  .slot.right { text-align: right; }
  .slot.center { text-align: center; }
  .wordmark {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 15px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
  }
  .wordmark:hover { text-decoration: none; }
  .back, .page-name { color: var(--oxide); }
  .page-name { color: var(--muted); }

  @media (max-width: 720px) {
    .masthead {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .slot.left, .slot.right { text-align: center; }
    /* Mobile: wordmark on its own line, "date . No. NNN" beneath, centered. */
    .slot.center { order: 1; }
    .slot.left { order: 2; }
    .slot.right { order: 3; }
    .wordmark { font-size: 14px; }
  }
</style>
