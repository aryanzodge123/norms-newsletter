---
import BaseLayout from '../layouts/BaseLayout.astro';
import EditionView from '../components/EditionView.astro';
import { latestEdition, neighbours } from '../lib/editions';
import { ogImagePath } from '../lib/urls';

const edition = await latestEdition();
const { prev } = await neighbours(edition.data.date);

const d = edition.data;
const title =
  d.edition_type === 'fallback'
    ? `Abbreviated edition · Norm's Newsletter`
    : `${d.headline_of_the_day} · Norm's Newsletter`;
---

<BaseLayout title={title} path="/" ogImagePath={ogImagePath(d.date)}>
  <EditionView edition={edition} prev={prev} />
</BaseLayout>
